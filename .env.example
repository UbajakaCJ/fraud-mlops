# ── FastAPI ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["*"]

# ── MongoDB ──────────────────────────────────────────────────
# Local Docker:
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=frauddb
# Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection
CHAMPION_MODEL_NAME=fraud-detector-champion

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
PREDICTION_CACHE_TTL=300

# ── Model ─────────────────────────────────────────────────────
MODEL_PATH=/app/model
PREDICTION_THRESHOLD=0.33
BATCH_LIMIT=10000

# ── Monitoring ────────────────────────────────────────────────
DRIFT_ALERT_THRESHOLD=0.15
LOG_LEVEL=info

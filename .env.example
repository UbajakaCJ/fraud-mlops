# ── FastAPI ──────────────────────────────────────────────────
# SECRET_KEY=change-me-to-a-random-32-char-string!!
SECRET_KEY=4e4745ecc91c0e24ff283017fa67e22805d885155c9014110e1a64eebdfc4977
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["*"]

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airflow:airflow@postgres/frauddb

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection
CHAMPION_MODEL_NAME=fraud-detector-champion

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
PREDICTION_CACHE_TTL=300

# ── Model ─────────────────────────────────────────────────────
MODEL_PATH=/app/model
PREDICTION_THRESHOLD=0.33
BATCH_LIMIT=10000

# ── Monitoring ────────────────────────────────────────────────
DRIFT_ALERT_THRESHOLD=0.15
LOG_LEVEL=info
